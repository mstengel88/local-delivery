{% liquid
  assign product_unit_label = blank
  if product and product.metafields.app.price_unit_label
    assign product_unit_label = product.metafields.app.price_unit_label.value
  endif
%}

<script id="ghs-price-unit-labels-data" type="application/json">
  {
    "pageType": {{ request.page_type | json }},
    "product": {% if product %}{
      "id": {{ product.id | json }},
      "handle": {{ product.handle | json }},
      "unitLabel": {{ product_unit_label | json }}
    }{% else %}null{% endif %},
    "collectionProducts": {
      {% if collection %}
        {% for collection_product in collection.products %}
          {% assign collection_unit_label = blank %}
          {% if collection_product.metafields.app.price_unit_label %}
            {% assign collection_unit_label = collection_product.metafields.app.price_unit_label.value %}
          {% endif %}
          {{ collection_product.handle | json }}: {{ collection_unit_label | json }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      {% endif %}
    }
  }
</script>

<div
  id="ghs-price-unit-labels-root"
  data-product-price-selector="{{ block.settings.product_price_selector | escape }}"
  data-card-price-selector="{{ block.settings.card_price_selector | escape }}"
  hidden
></div>

{% schema %}
{
  "name": "Price unit labels",
  "target": "body",
  "stylesheet": "price-unit-labels.css",
  "javascript": "price-unit-labels.js",
  "settings": [
    {
      "type": "text",
      "id": "product_price_selector",
      "label": "Optional product page price selector override",
      "info": "Leave blank to use automatic price detection."
    },
    {
      "type": "text",
      "id": "card_price_selector",
      "label": "Optional collection card price selector override",
      "info": "Leave blank to use automatic price detection."
    }
  ]
}
{% endschema %}
